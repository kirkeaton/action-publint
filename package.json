{
  "name": "action-publint",
  "version": "0.0.0-development",
  "description": "GitHub Action that lints a package.json file for packaging errors.",
  "author": "Kirk Eaton <contact@kirkeaton.ca>",
  "bugs": {
    "url": "https://github.com/kirkeaton/action-publint/issues"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "publint": "0.3.21"
  },
  "devDependencies": {
    "@kirkeaton/prettier-config": "2.0.0",
    "@kirkeaton/tsconfig": "3.0.0",
    "@types/node": "24.13.3",
    "esbuild": "0.28.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": "./dist/index.js",
  "files": [
    "dist"
  ],
  "funding": "https://kirkeaton.ca/sponsor",
  "homepage": "https://github.com/kirkeaton/action-publint#readme",
  "keywords": [
    "actions",
    "publish",
    "lint"
  ],
  "license": "BSD-3-Clause",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirkeaton/action-publint.git"
  },
  "scripts": {
    "build": "npm run clean && ./build.mjs",
    "clean": "rm -rf dist",
    "format": "prettier \"**/*.{json,md,mjs,mts}\" --write",
    "lint": "prettier \"**/*.{json,md,mjs,mts}\" --check",
    "typecheck": "tsc --noEmit"
  },
  "type": "commonjs"
}
